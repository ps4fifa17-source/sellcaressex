# Copy this to .env.local for local testing (never commit the real .env.local)
# In production, set these in Vercel: Project Settings -> Environment Variables

# Get this from resend.com after creating a free account
RESEND_API_KEY=

# The email address leads should land in — your team's actual inbox
DEALER_EMAIL=

# Optional: only works once you've verified sellcaressex.co in Resend.
# Until then, leave unset and it'll fall back to Resend's shared test address.
LEAD_FROM_EMAIL=
